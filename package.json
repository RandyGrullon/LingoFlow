{
  "name": "lingoflow",
  "private": true,
  "scripts": {
    "prepare": "pnpm run -r --filter \"./packages/*\" build",
    "dev": "pnpm --parallel --filter @lingoflow/web --filter @lingoflow/api dev",
    "dev:web": "pnpm --filter @lingoflow/web dev",
    "dev:api": "pnpm --filter @lingoflow/api dev",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint",
    "test": "pnpm run -r test"
  },
  "engines": {
    "node": ">=20"
  }
}
