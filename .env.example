# Copia este archivo a:
#   - apps/web/.env.local   (variables NEXT_PUBLIC_*)
#   - apps/api/.env         (resto)
# y rellena los valores desde el panel de Supabase (Settings → API).
# Nunca subas archivos .env al repositorio.

# --- apps/web (.env.local) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- apps/api (.env) ---
PORT=3001
CORS_ORIGIN=http://localhost:3000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Mismo valor que en Supabase → Settings → API → JWT Settings → JWT Secret (no es la anon key)
SUPABASE_JWT_SECRET=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
