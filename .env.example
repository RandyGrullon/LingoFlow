# Copia este archivo a `.env` en la RAÍZ del monorepo (una sola vez).
# Rellena los valores desde el panel de Supabase (Settings → API).
# Nunca subas `.env` al repositorio.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional: si está vacío en producción, el front usa /api/nest (proxy en next.config) y API_UPSTREAM_URL.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Origen del Nest para rewrites (mismo dominio público en Vercel). Ej: https://tu-api.vercel.app
API_UPSTREAM_URL=http://localhost:3001

PORT=3001
CORS_ORIGIN=http://localhost:3000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Mismo valor que en Supabase → Settings → API → JWT Settings → JWT Secret (no es la anon key)
SUPABASE_JWT_SECRET=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
